'3. Grading Engine'
SELECT 
    s.first_name, 
    s.last_name, 
    c.course_code, 
    g.assessment_name, 
    g.score_obtained, 
    g.max_score,
    ROUND((g.score_obtained / g.max_score) * 100, 2) AS assessment_percentage
FROM Grades g
JOIN Enrollments e ON g.enrollment_id = e.enrollment_id
JOIN Students s ON e.student_id = s.student_id
JOIN Courses c ON e.course_id = c.course_id;
'Final Report Card with Letter Grades'
SELECT 
    s.student_id,
    CONCAT(s.first_name, ' ', s.last_name) AS student_name,
    c.course_code,
    c.course_name,
    ROUND(AVG((g.score_obtained / g.max_score) * 100), 2) AS final_percentage,
    CASE 
        WHEN AVG((g.score_obtained / g.max_score) * 100) >= 90 THEN 'A'
        WHEN AVG((g.score_obtained / g.max_score) * 100) >= 80 THEN 'B'
        WHEN AVG((g.score_obtained / g.max_score) * 100) >= 70 THEN 'C'
        WHEN AVG((g.score_obtained / g.max_score) * 100) >= 60 THEN 'D'
        ELSE 'F'
    END AS final_letter_grade
FROM Students s
JOIN Enrollments e ON s.student_id = e.student_id
JOIN Courses c ON e.course_id = c.course_id
JOIN Grades g ON e.enrollment_id = g.enrollment_id
GROUP BY s.student_id, student_name, c.course_id, c.course_code, c.course_name
ORDER BY s.student_id ASC, final_percentage DESC;
