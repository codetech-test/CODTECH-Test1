'1. Database Schema'

CREATE DATABASE 
StudentGradingSystem;
USE StudentGradingSystem; 
CREATE TABLE Students ( student_id INTAUTO_INCREMENT PRIMARY KEY, first_name VARCHAR(50) NOT NULL, last_name VARCHAR(50) NOT NULL, email VARCHAR(100) UNIQUE NOT NULL ); 
CREATE TABLE Courses ( course_id INT AUTO_INCREMENT PRIMARY KEY, course_code VARCHAR(10) UNIQUE NOT NULL, course_name VARCHAR(100) NOT NULL, credits INT CHECK (credits > 0) ); 
CREATE TABLE Enrollments ( enrollment_id INT AUTO_INCREMENT PRIMARY KEY, student_id INT, course_id INT, FOREIGN KEY (student_id) REFERENCES Students(student_id), FOREIGN KEY (course_id) REFERENCES Courses(course_id) ); 

