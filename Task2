CREATE TABLE users (
    user_id SERIAL PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    joined_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
CREATE TABLE follows (
    follower_id INT REFERENCES users(user_id) ON DELETE CASCADE,
    following_id INT REFERENCES users(user_id) ON DELETE CASCADE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (follower_id, following_id),
    CONSTRAINT chk_not_self FOLLOWS (follower_id <> following_id) );
CREATE INDEX idx_follows_follower ON follows(follower_id);
CREATE INDEX idx_follows_following ON follows(following_id);
INSERT INTO users (username) VALUES ('Alice'), ('Bob'), ('Charlie'), ('David');
INSERT INTO follows (follower_id, following_id) VALUES 
(1, 2), 
(1, 3), 
(2, 3), 
(3, 4);
SELECT 
    u.username,
    COUNT(DISTINCT f1.following_id) AS following_count,
    COUNT(DISTINCT f2.follower_id) AS followers_count
FROM users u
LEFT JOIN follows f1 ON u.user_id = f1.follower_id
LEFT JOIN follows f2 ON u.user_id = f2.following_id
GROUP BY u.user_id, u.username
ORDER BY followers_count DESC;

